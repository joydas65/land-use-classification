{
  "displayName": "TerraClass Production Operations",
  "labels": {
    "ml": "",
    "production": "",
    "terraclass": ""
  },
  "mosaicLayout": {
    "columns": 12,
    "tiles": [
      {
        "xPos": 0,
        "yPos": 0,
        "width": 12,
        "height": 2,
        "widget": {
          "title": "Scope and claim boundary",
          "text": {
            "format": "MARKDOWN",
            "content": "Five-class TerraClass operational dashboard for service `terraclass-api` in `asia-south1`. Request and latency charts describe service behavior. Prediction logs are privacy-allowlisted. Candidate drift signals require at least 100 events per window and human review; this dashboard does not establish production accuracy, semantic drift, or an achieved SLO."
          }
        }
      },
      {
        "xPos": 0,
        "yPos": 2,
        "width": 6,
        "height": 4,
        "widget": {
          "title": "Cloud Run request rate by response class",
          "xyChart": {
            "dataSets": [
              {
                "plotType": "LINE",
                "targetAxis": "Y1",
                "timeSeriesQuery": {
                  "timeSeriesFilter": {
                    "filter": "metric.type=\"run.googleapis.com/request_count\" resource.type=\"cloud_run_revision\" resource.label.\"service_name\"=\"terraclass-api\" resource.label.\"location\"=\"asia-south1\"",
                    "aggregation": {
                      "alignmentPeriod": "60s",
                      "perSeriesAligner": "ALIGN_RATE",
                      "crossSeriesReducer": "REDUCE_SUM",
                      "groupByFields": [
                        "metric.label.\"response_code_class\""
                      ]
                    }
                  }
                }
              }
            ],
            "yAxis": {
              "label": "requests/second",
              "scale": "LINEAR"
            },
            "chartOptions": {
              "mode": "COLOR"
            }
          }
        }
      },
      {
        "xPos": 6,
        "yPos": 2,
        "width": 6,
        "height": 4,
        "widget": {
          "title": "Warm-container request latency p95",
          "xyChart": {
            "dataSets": [
              {
                "plotType": "LINE",
                "targetAxis": "Y1",
                "timeSeriesQuery": {
                  "timeSeriesFilter": {
                    "filter": "metric.type=\"run.googleapis.com/request_latencies\" resource.type=\"cloud_run_revision\" resource.label.\"service_name\"=\"terraclass-api\" resource.label.\"location\"=\"asia-south1\"",
                    "aggregation": {
                      "alignmentPeriod": "300s",
                      "perSeriesAligner": "ALIGN_PERCENTILE_95",
                      "crossSeriesReducer": "REDUCE_MAX"
                    }
                  }
                }
              }
            ],
            "thresholds": [
              {
                "value": 1000,
                "label": "Candidate warm p95 objective"
              }
            ],
            "yAxis": {
              "label": "milliseconds",
              "scale": "LINEAR"
            },
            "chartOptions": {
              "mode": "COLOR"
            }
          }
        }
      },
      {
        "xPos": 0,
        "yPos": 6,
        "width": 6,
        "height": 4,
        "widget": {
          "title": "Cloud Run instances by state",
          "xyChart": {
            "dataSets": [
              {
                "plotType": "STACKED_AREA",
                "targetAxis": "Y1",
                "timeSeriesQuery": {
                  "timeSeriesFilter": {
                    "filter": "metric.type=\"run.googleapis.com/container/instance_count\" resource.type=\"cloud_run_revision\" resource.label.\"service_name\"=\"terraclass-api\" resource.label.\"location\"=\"asia-south1\"",
                    "aggregation": {
                      "alignmentPeriod": "60s",
                      "perSeriesAligner": "ALIGN_MAX",
                      "crossSeriesReducer": "REDUCE_SUM",
                      "groupByFields": [
                        "metric.label.\"state\""
                      ]
                    }
                  }
                }
              }
            ],
            "yAxis": {
              "label": "instances",
              "scale": "LINEAR"
            },
            "chartOptions": {
              "mode": "COLOR"
            }
          }
        }
      },
      {
        "xPos": 6,
        "yPos": 6,
        "width": 6,
        "height": 4,
        "widget": {
          "title": "Privacy-allowlisted prediction observations",
          "logsPanel": {
            "filter": "resource.type=\"cloud_run_revision\"\nresource.labels.service_name=\"terraclass-api\"\nresource.labels.location=\"asia-south1\"\njsonPayload.event=\"prediction_observation\"",
            "resourceNames": [
              "projects/land-use-classification-502614"
            ]
          }
        }
      }
    ]
  }
}
