{
  "displayName": "TerraClass Cloud Run p95 container latency",
  "combiner": "OR",
  "enabled": true,
  "userLabels": {
    "application": "terraclass",
    "environment": "production",
    "objective": "steady-state-latency"
  },
  "documentation": {
    "content": "Investigate model loading, inference saturation, memory pressure, and revision changes. This GA metric begins at the running container and intentionally excludes scale-from-zero startup time.",
    "mimeType": "text/markdown"
  },
  "conditions": [
    {
      "displayName": "Cloud Run p95 request latency exceeds 1000 ms for 5 minutes",
      "conditionThreshold": {
        "filter": "metric.type=\"run.googleapis.com/request_latencies\" AND resource.type=\"cloud_run_revision\" AND resource.label.service_name=\"terraclass-api\"",
        "comparison": "COMPARISON_GT",
        "thresholdValue": 1000,
        "duration": "300s",
        "aggregations": [
          {
            "alignmentPeriod": "300s",
            "perSeriesAligner": "ALIGN_PERCENTILE_95",
            "crossSeriesReducer": "REDUCE_MAX",
            "groupByFields": [
              "resource.label.service_name"
            ]
          }
        ],
        "trigger": {
          "count": 1
        }
      }
    }
  ]
}
